	"entrypoints": {
		"main": [
			"com.afk.AFKHelper"
		],
		"client": [
			"com.afk.AfkClientMod"
		]
	},
	"mixins": [
		"afkhelper.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.18",
		"java": ">=17",
		"fabric": "*"
